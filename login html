<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Growexa AI — Sign In</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Inter',sans-serif}
body{background:#020818;color:#e2e8f0;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:100vh;position:relative;}
#canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}
body::before{content:'';position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 60% 50% at 20% 50%,rgba(0,60,160,.35) 0%,transparent 70%),
             radial-gradient(ellipse 50% 60% at 80% 40%,rgba(0,30,120,.30) 0%,transparent 70%),
             radial-gradient(ellipse 40% 40% at 50% 80%,rgba(0,100,200,.15) 0%,transparent 70%);
  pointer-events:none;}
.page{position:relative;z-index:10;width:100vw;height:100vh;display:grid;
  grid-template-columns:1fr auto 1fr;grid-template-rows:1fr auto 1fr;
  place-items:center;gap:0;padding:24px;}
.card{background:rgba(8,20,60,.75);border:1px solid rgba(100,160,255,.2);border-radius:16px;
  padding:18px 20px;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  box-shadow:0 4px 32px rgba(0,0,0,.5),inset 0 1px 0 rgba(100,160,255,.12);min-width:200px;
  animation:floatCard 6s ease-in-out infinite;transition:transform .3s,box-shadow .3s;}
.card:hover{transform:translateY(-4px)!important;box-shadow:0 8px 40px rgba(0,80,255,.25),inset 0 1px 0 rgba(100,160,255,.2);border-color:rgba(100,160,255,.4);}
@keyframes floatCard{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.card-label{font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:#7090c0;margin-bottom:8px;}
.card-sub{font-size:.7rem;color:#4a6080;margin-top:4px;}
.c-revenue{grid-column:1;grid-row:1;justify-self:end;align-self:end;animation-delay:0s}
.c-revenue .big{font-family:'Space Grotesk',sans-serif;font-size:1.7rem;font-weight:700;color:#fff;}
.c-revenue .delta{font-size:.82rem;font-weight:600;color:#1FE0A6;margin-left:8px;}
.c-revenue .sparkline{display:flex;align-items:flex-end;gap:3px;height:40px;margin-top:10px;}
.c-ai{grid-column:2;grid-row:1;align-self:end;animation-delay:1.2s;min-width:160px;}
.pulse-dot{width:8px;height:8px;border-radius:50%;background:#1FE0A6;box-shadow:0 0 8px #1FE0A6;animation:pulse 1.5s ease-in-out infinite;display:inline-block;margin-right:6px;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.85)}}
.c-profit{grid-column:3;grid-row:1;justify-self:start;align-self:end;animation-delay:.6s;}
.c-profit .ring-wrap{display:flex;align-items:center;gap:14px;margin-top:8px;}
.c-profit .ring{position:relative;width:60px;height:60px;}
.c-profit .ring svg{transform:rotate(-90deg);}
.c-profit .ring-pct{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-size:.82rem;font-weight:700;color:#fff;}
.c-profit .ring-info .val{font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700;color:#1FE0A6;}
.c-profit .ring-info .lbl{font-size:.7rem;color:#4a6080;}
.c-darkmode{grid-column:3;grid-row:1;justify-self:end;align-self:start;min-width:140px;padding:14px 16px;animation-delay:2s;}
.c-darkmode .toggle-row{display:flex;align-items:center;justify-content:space-between;margin-top:6px;}
.pill{width:40px;height:22px;background:linear-gradient(90deg,#2563eb,#06b6d4);border-radius:999px;position:relative;cursor:pointer;}
.pill::after{content:'';position:absolute;right:3px;top:3px;width:16px;height:16px;background:#fff;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,.3);}
.c-segments{grid-column:1;grid-row:2;justify-self:end;align-self:center;animation-delay:.4s;}
.seg-dots{display:flex;flex-direction:column;gap:6px;margin-top:10px;}
.seg-dot-row{display:flex;align-items:center;gap:8px;font-size:.72rem;color:#7090c0;}
.seg-dot-row .dot{width:8px;height:8px;border-radius:50%;}
.c-predict{grid-column:3;grid-row:2;justify-self:start;align-self:center;animation-delay:1.8s;min-width:220px;}
.spark-line{height:50px;margin-top:10px;overflow:hidden;}
.c-predict .acc{font-family:'Space Grotesk',sans-serif;font-size:1.3rem;font-weight:700;color:#1FE0A6;margin-top:8px;}
.c-predict .acc-lbl{font-size:.7rem;color:#4a6080;}
.c-customers{grid-column:1;grid-row:3;justify-self:end;align-self:start;animation-delay:2.4s;}
.c-customers .big{font-family:'Space Grotesk',sans-serif;font-size:1.6rem;font-weight:700;color:#fff;}
.c-customers .delta{font-size:.8rem;font-weight:600;color:#1FE0A6;margin-left:8px;}
.avatar-row{display:flex;align-items:center;margin-top:10px;}
.av{width:26px;height:26px;border-radius:50%;border:2px solid rgba(8,20,60,.9);background:linear-gradient(135deg,#1e40af,#06b6d4);display:inline-flex;align-items:center;justify-content:center;font-size:.55rem;font-weight:700;color:#fff;margin-left:-6px;}
.av:first-child{margin-left:0;}
.av-more{font-size:.68rem;color:#1FE0A6;font-weight:600;margin-left:8px;}
.c-decision{grid-column:3;grid-row:3;justify-self:start;align-self:start;animation-delay:3s;min-width:210px;}
.check-list{display:flex;flex-direction:column;gap:5px;margin-top:10px;}
.check-item{display:flex;align-items:center;gap:7px;font-size:.72rem;color:#7090c0;}
.check-item .ck{color:#1FE0A6;font-size:.75rem;}
.c-decision .conf{font-family:'Space Grotesk',sans-serif;font-size:.95rem;font-weight:700;color:#1FE0A6;margin-top:10px;}
.c-decision .conf span{font-size:.7rem;color:#4a6080;font-weight:400;margin-left:4px;}
.c-market{grid-column:2;grid-row:3;align-self:start;animation-delay:1s;min-width:180px;}
.c-growth{grid-column:3;grid-row:3;justify-self:end;align-self:end;animation-delay:2.8s;}
.c-growth .big{font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:700;color:#fff;}
.c-growth .delta{font-size:.8rem;font-weight:600;color:#1FE0A6;margin-left:6px;}
.growth-line{height:40px;margin-top:10px;}
svg{display:block;fill:none;}
.center-col{grid-column:2;grid-row:1/4;display:flex;flex-direction:column;align-items:center;gap:0;z-index:20;width:380px;}
.logo-wrap{display:flex;flex-direction:column;align-items:center;margin-bottom:24px;animation:logoIn .8s cubic-bezier(.2,0,.2,1) both;}
@keyframes logoIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:none}}
.logo-icon{width:80px;height:80px;margin-bottom:12px;}
.logo-name{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:800;letter-spacing:-.02em;color:#fff;display:flex;align-items:center;gap:8px;}
.logo-badge{background:linear-gradient(135deg,#2563eb,#06b6d4);color:#fff;font-size:.6rem;font-weight:700;padding:2px 6px;border-radius:5px;letter-spacing:.08em;vertical-align:middle;}
.logo-tagline{font-size:.8rem;color:#4a6080;letter-spacing:.15em;text-transform:uppercase;margin-top:4px;}
.login-card{background:rgba(6,14,46,.85);border:1px solid rgba(100,160,255,.18);border-radius:20px;padding:32px 32px 28px;backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);box-shadow:0 24px 80px rgba(0,0,0,.6),inset 0 1px 0 rgba(100,160,255,.15);width:100%;animation:cardIn .6s .2s cubic-bezier(.2,0,.2,1) both;}
@keyframes cardIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
.login-title{font-family:'Space Grotesk',sans-serif;font-size:1.4rem;font-weight:700;color:#fff;text-align:center;margin-bottom:4px;}
.login-sub{font-size:.8rem;color:#4a6080;text-align:center;margin-bottom:22px;}
.btn-google{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;background:#fff;border:none;border-radius:10px;padding:12px;font-family:'Space Grotesk',sans-serif;font-size:.9rem;font-weight:600;color:#1a1a2e;cursor:pointer;transition:transform .15s,box-shadow .15s;box-shadow:0 2px 12px rgba(0,0,0,.3);}
.btn-google:hover{background:#f8fafc;transform:translateY(-1px);box-shadow:0 4px 20px rgba(0,0,0,.4);}
.btn-google:active{transform:translateY(0);}
.g-icon{width:20px;height:20px;flex-shrink:0;}
.divider{display:flex;align-items:center;gap:12px;margin:18px 0;font-size:.72rem;color:#2a3a5a;letter-spacing:.08em;}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:rgba(100,160,255,.15);}
.field{position:relative;margin-bottom:14px;}
.field-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:#2a3a5a;}
.field input{width:100%;background:rgba(10,20,60,.6);border:1px solid rgba(100,160,255,.18);border-radius:10px;padding:12px 14px 12px 40px;font-size:.85rem;color:#e2e8f0;outline:none;transition:border-color .2s,background .2s,box-shadow .2s;}
.field input::placeholder{color:#2a3a5a;}
.field input:focus{border-color:rgba(37,99,235,.7);background:rgba(10,20,80,.7);box-shadow:0 0 0 3px rgba(37,99,235,.15);}
.eye-btn{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#2a3a5a;padding:2px;}
.eye-btn:hover{color:#7090c0;}
.eye-btn svg{width:16px;height:16px;}
.form-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;font-size:.78rem;}
.remember{display:flex;align-items:center;gap:7px;color:#7090c0;cursor:pointer;}
.remember input[type=checkbox]{width:16px;height:16px;accent-color:#2563eb;cursor:pointer;}
.forgot{color:#3b82f6;text-decoration:none;font-weight:500;transition:color .15s;}
.forgot:hover{color:#60a5fa;}
.btn-signin{width:100%;background:linear-gradient(90deg,#2563eb 0%,#06b6d4 50%,#1FE0A6 100%);border:none;border-radius:10px;padding:13px;font-family:'Space Grotesk',sans-serif;font-size:.95rem;font-weight:700;color:#fff;letter-spacing:.03em;cursor:pointer;position:relative;overflow:hidden;box-shadow:0 4px 20px rgba(37,99,235,.4);transition:transform .15s,box-shadow .15s;}
.btn-signin::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,.15) 50%,transparent 100%);transform:translateX(-100%);transition:transform .5s;}
.btn-signin:hover{transform:translateY(-1px);box-shadow:0 6px 28px rgba(37,99,235,.5);}
.btn-signin:hover::after{transform:translateX(100%);}
.btn-signin:active{transform:translateY(0);}
.btn-signin .spinner{display:none;width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:8px;}
@keyframes spin{to{transform:rotate(360deg)}}
.signup-row{text-align:center;margin-top:18px;font-size:.78rem;color:#2a3a5a;}
.signup-row a{color:#3b82f6;font-weight:600;text-decoration:none;transition:color .15s;}
.signup-row a:hover{color:#60a5fa;}
.error-msg{display:none;background:rgba(255,80,80,.12);border:1px solid rgba(255,80,80,.25);border-radius:8px;padding:10px 14px;font-size:.78rem;color:#f87171;margin-bottom:14px;text-align:center;}
.error-msg.show{display:block;}
@media(max-width:900px){.card{display:none;}.page{grid-template-columns:1fr;grid-template-rows:auto;}body{overflow:auto;}.center-col{grid-column:1;grid-row:1;width:min(100%,380px);}}
</style>
</head>
<body>
<canvas id="canvas"></canvas>
<div class="page">

  <div class="card c-revenue">
    <div class="card-label">Revenue Growth</div>
    <div><span class="big">$24.8M</span><span class="delta">+23.6%</span></div>
    <div class="card-sub">vs Last Quarter</div>
    <div class="sparkline" id="revBars"></div>
  </div>

  <div class="card c-segments">
    <div class="card-label">Customer Segments</div>
    <div id="segViz" style="width:120px;height:80px;margin:8px auto 0;"></div>
    <div class="seg-dots">
      <div class="seg-dot-row"><span class="dot" style="background:#1FE0A6"></span>High Value</div>
      <div class="seg-dot-row"><span class="dot" style="background:#3b82f6"></span>Medium Value</div>
      <div class="seg-dot-row"><span class="dot" style="background:#06b6d4"></span>Growing</div>
    </div>
  </div>

  <div class="card c-customers">
    <div class="card-label">Total Customers</div>
    <div><span class="big">12,847</span><span class="delta">+18.2%</span></div>
    <div class="card-sub">vs Last Month</div>
    <div class="avatar-row">
      <div class="av">RS</div><div class="av">PK</div><div class="av">AM</div><div class="av">NH</div><div class="av">KJ</div>
      <span class="av-more">+2.3K</span>
    </div>
  </div>

  <div class="center-col">
    <div class="logo-wrap">
      <svg class="logo-icon" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#2563eb"/><stop offset="50%" stop-color="#06b6d4"/><stop offset="100%" stop-color="#1FE0A6"/>
          </linearGradient>
          <linearGradient id="lg2" x1="0%" y1="100%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#1FE0A6"/><stop offset="100%" stop-color="#2563eb"/>
          </linearGradient>
        </defs>
        <circle cx="40" cy="40" r="36" stroke="url(#lg1)" stroke-width="3" fill="none" opacity=".5"/>
        <path d="M40 10 A30 30 0 1 0 68 48" stroke="url(#lg1)" stroke-width="5" stroke-linecap="round" fill="none"/>
        <polyline points="52,28 65,15 65,28" stroke="url(#lg2)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <line x1="65" y1="15" x2="48" y2="15" stroke="url(#lg2)" stroke-width="4" stroke-linecap="round"/>
        <rect x="28" y="48" width="5" height="10" rx="1.5" fill="url(#lg1)" opacity=".7"/>
        <rect x="35" y="43" width="5" height="15" rx="1.5" fill="url(#lg1)" opacity=".85"/>
        <rect x="42" y="38" width="5" height="20" rx="1.5" fill="url(#lg2)"/>
      </svg>
      <div class="logo-name">Growexa <span class="logo-badge">AI</span></div>
      <div class="logo-tagline">Insights &nbsp;·&nbsp; Optimize &nbsp;·&nbsp; Grow</div>
    </div>

    <div class="login-card">
      <div class="login-title">Welcome Back</div>
      <div class="login-sub">Sign in to your Growexa AI account</div>
      <div class="error-msg" id="errorMsg"></div>

      <button class="btn-google" id="btnGoogle" type="button">
        <svg class="g-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>

      <div class="divider">or continue with email</div>

      <div class="field">
        <svg class="field-icon" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor"/>
          <polyline points="22,6 12,13 2,6" stroke="currentColor"/>
        </svg>
        <input type="email" id="emailInput" placeholder="Enter your email" autocomplete="email">
      </div>

      <div class="field">
        <svg class="field-icon" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke="currentColor"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor"/>
        </svg>
        <input type="password" id="pwInput" placeholder="Enter your password" autocomplete="current-password">
        <button class="eye-btn" id="eyeBtn" type="button" aria-label="Toggle password visibility">
          <svg id="eyeOpen" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor"/>
            <circle cx="12" cy="12" r="3" stroke="currentColor"/>
          </svg>
          <svg id="eyeClosed" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="display:none">
            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" stroke="currentColor"/>
            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" stroke="currentColor"/>
            <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor"/>
          </svg>
        </button>
      </div>

      <div class="form-row">
        <label class="remember"><input type="checkbox" id="rememberMe" checked> Remember Me</label>
        <a href="#" class="forgot">Forgot Password?</a>
      </div>

      <button class="btn-signin" id="btnSignin" type="button">
        <span class="spinner" id="spinner"></span>
        <span id="btnLabel">Sign In</span>
      </button>

      <div class="signup-row">Don't have an account? <a href="#">Sign up here</a></div>
    </div>
  </div>

  <div class="card c-darkmode">
    <div class="card-label">Dark Mode</div>
    <div class="toggle-row"><span style="font-size:.72rem;color:#7090c0">Active</span><div class="pill"></div></div>
  </div>

  <div class="card c-profit">
    <div class="card-label">Profit Optimization</div>
    <div class="ring-wrap">
      <div class="ring">
        <svg width="60" height="60" viewBox="0 0 60 60">
          <circle cx="30" cy="30" r="24" stroke="rgba(100,160,255,.15)" stroke-width="5" fill="none"/>
          <defs><linearGradient id="rg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#1FE0A6"/></linearGradient></defs>
          <circle cx="30" cy="30" r="24" stroke="url(#rg)" stroke-width="5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="22.6" stroke-linecap="round"/>
        </svg>
        <div class="ring-pct">89%</div>
      </div>
      <div class="ring-info">
        <div class="val">+15.3%</div>
        <div class="lbl">Optimization Score</div>
        <div class="lbl" style="margin-top:2px;">vs Last Month</div>
      </div>
    </div>
  </div>

  <div class="card c-predict">
    <div class="card-label">Predictive Analytics</div>
    <div class="spark-line">
      <svg width="100%" height="50" viewBox="0 0 200 50" preserveAspectRatio="none">
        <defs><linearGradient id="slg" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#1FE0A6"/></linearGradient></defs>
        <path d="M0 40 C20 38 30 30 50 28 S80 20 100 22 S140 14 160 16 S185 10 200 8" stroke="url(#slg)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M0 40 C20 38 30 30 50 28 S80 20 100 22 S140 14 160 16 S185 10 200 8 L200 50 L0 50 Z" fill="url(#slg)" opacity=".1"/>
      </svg>
    </div>
    <div class="acc">95%</div>
    <div class="acc-lbl">Accuracy Rate</div>
  </div>

  <div class="card c-decision">
    <div class="card-label">AI Decision Engine</div>
    <div class="card-sub">Processing…</div>
    <div class="check-list">
      <div class="check-item"><span class="ck">✓</span> Data Analyzed</div>
      <div class="check-item"><span class="ck">✓</span> Pattern Recognition</div>
      <div class="check-item"><span class="ck">✓</span> Predictive Model</div>
      <div class="check-item"><span class="ck">✓</span> Optimization</div>
    </div>
    <div class="conf">99.7% <span>Confidence</span></div>
  </div>

  <div class="card c-market">
    <div class="card-label">Market Intelligence</div>
    <div class="card-sub">Competitive Advantage</div>
    <div style="display:flex;align-items:center;gap:12px;margin-top:8px;">
      <div style="position:relative;width:50px;height:50px;">
        <svg width="50" height="50" viewBox="0 0 50 50">
          <circle cx="25" cy="25" r="20" stroke="rgba(100,160,255,.15)" stroke-width="4" fill="none"/>
          <circle cx="25" cy="25" r="20" stroke="#3b82f6" stroke-width="4" fill="none" stroke-dasharray="125.6" stroke-dashoffset="15" stroke-linecap="round" transform="rotate(-90 25 25)"/>
        </svg>
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-size:.75rem;font-weight:700;color:#fff;">87%</div>
      </div>
      <div id="mktBars" style="display:flex;align-items:flex-end;gap:3px;height:40px;"></div>
    </div>
  </div>

  <div class="card c-growth">
    <div class="card-label">Growth Pipeline</div>
    <div><span class="big">$156M</span><span class="delta">+31.8%</span></div>
    <div class="card-sub">vs Last Quarter</div>
    <div class="growth-line">
      <svg width="100%" height="40" viewBox="0 0 160 40" preserveAspectRatio="none">
        <defs><linearGradient id="glg" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#1FE0A6"/></linearGradient></defs>
        <path d="M0 38 C30 36 40 30 60 26 S100 18 120 14 S145 8 160 4" stroke="url(#glg)" stroke-width="2" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

</div>

<script>
// Every decorative animation below is wrapped in try/catch so that if any
// one of them throws (missing element, canvas unsupported, etc.) it can
// NEVER block the real Sign In logic further down this script from
// running.

try {
  (function(){
    const cv=document.getElementById('canvas'),ctx=cv.getContext('2d');
    let W,H,nodes=[];
    const N=85,DIST=165,COLS=['#2563eb','#06b6d4','#1FE0A6','#3b82f6','#1d4ed8'];
    function resize(){W=cv.width=window.innerWidth;H=cv.height=window.innerHeight;}
    resize();window.addEventListener('resize',resize);
    function rnd(a,b){return a+Math.random()*(b-a);}
    for(let i=0;i<N;i++) nodes.push({x:rnd(0,W),y:rnd(0,H),vx:rnd(-.28,.28),vy:rnd(-.28,.28),r:rnd(1.5,3.5),c:COLS[i%COLS.length],o:rnd(.3,.9)});
    function draw(){
      ctx.clearRect(0,0,W,H);
      for(let i=0;i<nodes.length;i++){
        for(let j=i+1;j<nodes.length;j++){
          const dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);
          if(d<DIST){ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle=`rgba(100,160,255,${(1-d/DIST)*.22})`;ctx.lineWidth=.7;ctx.stroke();}
        }
      }
      nodes.forEach(n=>{
        ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=n.c;ctx.globalAlpha=n.o;ctx.fill();
        const g=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*3.5);
        g.addColorStop(0,n.c+'55');g.addColorStop(1,'transparent');
        ctx.beginPath();ctx.arc(n.x,n.y,n.r*3.5,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
        ctx.globalAlpha=1;
        n.x+=n.vx;n.y+=n.vy;
        if(n.x<-10)n.x=W+10;if(n.x>W+10)n.x=-10;
        if(n.y<-10)n.y=H+10;if(n.y>H+10)n.y=-10;
      });
      requestAnimationFrame(draw);
    }
    draw();
  })();
} catch (e) { console.warn('particle background failed (safe to ignore):', e); }

try {
  (function(){
    const vals=[30,40,35,55,50,65,70,60,80,90,85,100];
    const c=document.getElementById('revBars');if(!c)return;
    const max=Math.max(...vals);
    vals.forEach(v=>{const b=document.createElement('div');b.style.cssText=`flex:1;border-radius:3px 3px 0 0;background:linear-gradient(180deg,#3b82f6,#1e40af);opacity:.75;height:${(v/max)*100}%;min-height:4px;align-self:flex-end;`;c.appendChild(b);});
  })();
} catch (e) { console.warn('revenue sparkline failed (safe to ignore):', e); }

try {
  (function(){
    const vals=[40,60,50,75,65,80,70,90];const c=document.getElementById('mktBars');if(!c)return;
    const max=Math.max(...vals);
    vals.forEach(v=>{const b=document.createElement('div');b.style.cssText=`width:10px;border-radius:2px 2px 0 0;background:linear-gradient(180deg,#3b82f6,#1e3a8a);height:${(v/max)*100}%;min-height:3px;`;c.appendChild(b);});
  })();
} catch (e) { console.warn('market bars failed (safe to ignore):', e); }

try {
  (function(){
    const el=document.getElementById('segViz');if(!el)return;
    const clusters=[{x:45,y:40,c:'#1FE0A6',n:8},{x:60,y:55,c:'#1FE0A6',n:5},{x:30,y:60,c:'#3b82f6',n:7},{x:75,y:35,c:'#3b82f6',n:5},{x:55,y:70,c:'#06b6d4',n:6},{x:35,y:45,c:'#06b6d4',n:4}];
    let m='<svg viewBox="0 0 120 80" width="120" height="80" style="overflow:visible">';
    clusters.forEach(d=>{for(let i=0;i<d.n;i++){const ox=(Math.random()-.5)*22,oy=(Math.random()-.5)*18;m+=`<circle cx="${d.x+ox}" cy="${d.y+oy}" r="3" fill="${d.c}" opacity="${(.4+Math.random()*.6).toFixed(2)}"/>`;}});
    el.innerHTML=m+'</svg>';
  })();
} catch (e) { console.warn('segment viz failed (safe to ignore):', e); }

// ---- Real sign-in logic below. This now always runs, no matter what
// happened with the decorative animations above. ----

console.log('Growexa login script loaded. Sign In button wiring up now.');

const eyeBtn = document.getElementById('eyeBtn');
if (eyeBtn) {
  eyeBtn.addEventListener('click', function(){
    const inp=document.getElementById('pwInput'),isT=inp.type==='text';
    inp.type=isT?'password':'text';
    document.getElementById('eyeOpen').style.display=isT?'':'none';
    document.getElementById('eyeClosed').style.display=isT?'none':'';
  });
}

const btnSignin = document.getElementById('btnSignin');
if (btnSignin) {
  btnSignin.addEventListener('click', function(){
    console.log('Sign In clicked.');
    const email=document.getElementById('emailInput').value.trim();
    const pw=document.getElementById('pwInput').value;
    const err=document.getElementById('errorMsg');
    err.classList.remove('show');
    if(!email||!pw){err.textContent='Please enter both email and password.';err.classList.add('show');console.log('Blocked: missing email/password');return;}
    if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){err.textContent='Please enter a valid email address.';err.classList.add('show');console.log('Blocked: invalid email format');return;}
    console.log('Validation passed, redirecting to /dashboard in 1.8s...');
    document.getElementById('spinner').style.display='inline-block';
    document.getElementById('btnLabel').textContent='Signing In\u2026';
    this.style.pointerEvents='none';
    setTimeout(()=>{ window.location.href='/dashboard'; },1800);
  });
} else {
  console.error('btnSignin element not found — the button in the HTML is missing or has a different id.');
}

const btnGoogle = document.getElementById('btnGoogle');
if (btnGoogle) {
  btnGoogle.addEventListener('click', function(){
    this.textContent='Redirecting\u2026';
    setTimeout(()=>{ window.location.href='/dashboard'; },1000);
  });
}

['emailInput','pwInput'].forEach(id=>{
  const el = document.getElementById(id);
  if (el) el.addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('btnSignin').click();});
});
</script>
</body>
</html>
